<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>一日日记</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg-deep:#0f0f14;--bg-mid:#1a1a24;--card-bg:rgba(255,255,255,0.06);
  --card-border:rgba(255,255,255,0.08);--text-primary:#e8e4df;--text-secondary:#8a8690;
  --accent:#c9a87c;--accent-glow:rgba(201,168,124,0.25);--danger:#e05555;
  --danger-glow:rgba(224,85,85,0.2);--success:#6abf8a;--radius:12px;
  --delete-red:rgba(224,85,85,0.35);
  --macaron-blue:#8ec5e8;--macaron-green:#a8d8b0;--macaron-pink:#f0a8b8;
  --macaron-blue-glow:rgba(142,197,232,0.25);--macaron-green-glow:rgba(168,216,176,0.25);--macaron-pink-glow:rgba(240,168,184,0.25);
}
html,body{height:100%;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Noto Sans SC","PingFang SC","Microsoft YaHei",sans-serif;background:var(--bg-deep);color:var(--text-primary);overflow-x:hidden}
body{display:flex;flex-direction:column;min-height:100vh;position:relative}
body::before{content:'';position:fixed;top:-30%;left:-10%;width:60%;height:60%;background:radial-gradient(ellipse,rgba(201,168,124,0.04) 0%,transparent 70%);pointer-events:none;z-index:0}
body::after{content:'';position:fixed;bottom:-20%;right:-10%;width:50%;height:50%;background:radial-gradient(ellipse,rgba(120,100,180,0.03) 0%,transparent 70%);pointer-events:none;z-index:0}

/* Header */
.header{position:relative;z-index:1;text-align:center;padding:40px 20px 20px;animation:fadeDown .6s ease}
.header-top{display:flex;align-items:center;justify-content:flex-end;padding:0 4px;margin-bottom:-4px}
.header-settings{width:32px;height:32px;border:1px solid var(--card-border);border-radius:50%;background:transparent;color:var(--text-secondary);font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s}
.header-settings:hover{border-color:var(--accent);color:var(--accent)}
.header-nav{display:flex;align-items:center;justify-content:center;gap:16px}
.header-arrow{width:36px;height:36px;border:1px solid var(--card-border);border-radius:50%;background:transparent;color:var(--text-secondary);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s}
.header-arrow:hover{border-color:var(--accent);color:var(--accent)}
.header-arrow:disabled{opacity:.2;cursor:default;pointer-events:none}
.header-center{min-width:200px}
.header-date{font-size:28px;font-weight:300;letter-spacing:2px;color:var(--text-primary)}
.header-weekday{font-size:14px;color:var(--text-secondary);margin-top:6px;letter-spacing:4px;text-transform:uppercase}
.header-line{width:40px;height:1px;background:var(--accent);margin:16px auto 0;opacity:.5}
.header-today-badge{display:inline-block;font-size:11px;background:var(--accent-glow);color:var(--accent);padding:2px 10px;border-radius:10px;margin-top:8px;letter-spacing:1px}

/* Sync indicator */
.sync-indicator{display:inline-flex;align-items:center;gap:4px;font-size:11px;margin-top:6px;padding:2px 10px;border-radius:10px;letter-spacing:.5px}
.sync-off{background:rgba(255,255,255,0.05);color:var(--text-secondary)}
.sync-on{background:rgba(106,191,138,0.12);color:#6abf8a}
.sync-dot{width:6px;height:6px;border-radius:50%;display:inline-block}
.sync-off .sync-dot{background:var(--text-secondary)}
.sync-on .sync-dot{background:#6abf8a;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

/* Refresh button */
#syncIndicator{display:inline-flex;align-items:center;gap:6px;margin-top:6px}
.refresh-btn{display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;border-radius:50%;font-size:28px;cursor:pointer;color:var(--macaron-pink);transition:all .2s;user-select:none}
.refresh-btn:hover{color:var(--macaron-pink);background:rgba(240,168,184,0.1);transform:rotate(90deg)}
.refresh-btn:active{transform:rotate(270deg)}

/* Settings modal extras */
.settings-label{font-size:12px;color:var(--text-secondary);margin-bottom:6px;letter-spacing:.5px}
.settings-input{width:100%;padding:10px 14px;background:rgba(0,0,0,0.3);border:1px solid var(--card-border);border-radius:10px;color:var(--text-primary);font-size:14px;outline:none;font-family:inherit;transition:border-color .2s}
.settings-input:focus{border-color:var(--accent)}
.settings-input::placeholder{color:var(--text-secondary);opacity:.5}
.settings-hint{font-size:12px;color:var(--text-secondary);line-height:1.5;margin-top:8px}
.settings-status{display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:10px;margin-top:12px;font-size:13px}
.settings-status-off{background:rgba(255,255,255,0.03);color:var(--text-secondary)}
.settings-status-on{background:rgba(106,191,138,0.08);color:#6abf8a}
.settings-status-err{background:var(--danger-glow);color:var(--danger)}
.settings-section{margin-bottom:18px}
.settings-section:last-child{margin-bottom:0}

/* Main content area */
.main{flex:1;position:relative;z-index:1;padding:20px 20px 120px;max-width:800px;width:100%;margin:0 auto}

/* Cards grid */
.cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}
@media(max-width:480px){.cards-grid{grid-template-columns:1fr;gap:12px}}

/* Card wrapper for swipe */
.card-wrapper{position:relative;overflow:hidden;border-radius:var(--radius);animation:cardIn .35s ease backwards}

/* Card */
.card{background:var(--card-bg);border:1px solid var(--card-border);border-right:4px solid var(--delete-red);border-radius:var(--radius);padding:20px;position:relative;cursor:default;transition:transform .2s ease,box-shadow .2s ease,opacity .15s ease;min-height:60px;z-index:1}
.card:hover{border-color:rgba(255,255,255,0.14);border-right-color:rgba(224,85,85,0.5);background:rgba(255,255,255,0.08);transform:translateY(-1px)}
.card.swiping{transition:none}
.card.swiping-deleting{background:rgba(224,85,85,0.12);border-color:rgba(224,85,85,0.25)}
.card-text{white-space:pre-wrap;word-break:break-word;line-height:1.7;font-size:15px;color:var(--text-primary)}

/* Editing state */
.card.editing{border-color:var(--accent);border-right-color:var(--accent);box-shadow:0 0 20px var(--accent-glow);background:rgba(201,168,124,0.05)}
.card-edit-area{width:100%;min-height:80px;background:transparent;border:none;color:var(--text-primary);font-size:15px;line-height:1.7;resize:vertical;outline:none;font-family:inherit}
.card-edit-actions{display:flex;gap:8px;margin-top:12px;justify-content:flex-end}

/* New card form */
.new-card{background:var(--card-bg);border:1px dashed var(--accent);border-radius:var(--radius);padding:20px;animation:cardIn .3s ease}
.new-card-textarea{width:100%;min-height:100px;background:transparent;border:none;color:var(--text-primary);font-size:15px;line-height:1.7;resize:vertical;outline:none;font-family:inherit}
.new-card-textarea::placeholder{color:var(--text-secondary)}
.new-card-actions{display:flex;gap:8px;margin-top:12px;justify-content:flex-end}

/* Buttons */
.btn{padding:8px 18px;border:none;border-radius:8px;font-size:13px;cursor:pointer;transition:all .2s;font-family:inherit;letter-spacing:.5px}
.btn-primary{background:var(--accent);color:#1a1a24}
.btn-primary:hover{filter:brightness(1.1);transform:translateY(-1px)}
.btn-ghost{background:transparent;color:var(--text-secondary);border:1px solid var(--card-border)}
.btn-ghost:hover{border-color:var(--text-secondary);color:var(--text-primary)}
.btn-danger{background:var(--danger-glow);color:var(--danger);border:1px solid rgba(224,85,85,0.2)}
.btn-danger:hover{background:rgba(224,85,85,0.3)}
.btn-success{background:var(--macaron-green);color:#2a5c34;border:none;font-weight:500}
.btn-success:hover{filter:brightness(1.08);transform:translateY(-1px)}

/* Bottom bar */
.bottom-bar{position:fixed;bottom:36px;left:50%;transform:translateX(-50%);z-index:10;background:var(--bg-mid);border:1px solid var(--card-border);padding:10px 20px;display:flex;justify-content:center;align-items:center;gap:14px;border-radius:18px;box-shadow:0 8px 32px rgba(0,0,0,0.5);transition:opacity .25s ease,transform .25s ease}
.bottom-bar .btn{padding:0 24px;font-size:16px;border-radius:28px;height:48px;display:inline-flex;align-items:center;justify-content:center;white-space:nowrap}
.btn-merge{background:var(--macaron-blue);color:#2a4a5c;border:none;font-weight:500}
.btn-merge:hover{filter:brightness(1.08);transform:translateY(-1px);box-shadow:0 4px 16px var(--macaron-blue-glow)}
.btn-add{background:var(--macaron-green);color:#2a5c34;font-size:16px;width:144px;height:48px;padding:0;border-radius:24px;display:inline-flex;align-items:center;justify-content:center;box-shadow:0 4px 20px var(--macaron-green-glow);transition:all .25s;font-weight:500;border:none;white-space:nowrap}
.btn-add:hover{transform:scale(1.05);box-shadow:0 6px 28px var(--macaron-green-glow)}
.btn-add:active{transform:scale(.95)}
.btn-clear{background:var(--macaron-pink);color:#5c2a34;border:none;font-weight:500}
.btn-clear:hover{filter:brightness(1.08);transform:translateY(-1px);box-shadow:0 4px 16px var(--macaron-pink-glow)}

/* Modal overlay */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);z-index:100;display:flex;align-items:center;justify-content:center;padding:20px;animation:fadeIn .2s ease}
.modal{background:var(--bg-mid);border:1px solid var(--card-border);border-radius:16px;padding:28px;max-width:520px;width:100%;max-height:80vh;display:flex;flex-direction:column;animation:modalIn .25s ease}
.modal-title{font-size:18px;font-weight:500;margin-bottom:16px;color:var(--text-primary)}
.modal-body{flex:1;overflow-y:auto;margin-bottom:20px}
.modal-merged-text{background:rgba(0,0,0,0.3);border-radius:10px;padding:16px;white-space:pre-wrap;word-break:break-word;line-height:1.8;font-size:14px;color:var(--text-primary);max-height:50vh;overflow-y:auto}
.modal-actions{display:flex;gap:8px;justify-content:flex-end}

/* Confirm modal */
.confirm-icon{font-size:40px;text-align:center;margin-bottom:12px}
.confirm-text{text-align:center;color:var(--text-secondary);line-height:1.6;margin-bottom:20px}

/* Empty state */
.empty-state{text-align:center;padding:80px 20px;color:var(--text-secondary);animation:fadeIn .5s ease}
.empty-state-icon{font-size:48px;margin-bottom:16px;opacity:.3}
.empty-state-text{font-size:15px;line-height:1.8}

/* Animations */
@keyframes fadeDown{from{opacity:0;transform:translateY(-12px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes cardIn{from{opacity:0;transform:translateY(10px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes modalIn{from{opacity:0;transform:scale(.95)}to{opacity:1;transform:scale(1)}}

/* Scrollbar */
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:4px}

/* Toast */
.toast{position:fixed;top:24px;left:50%;transform:translateX(-50%);background:var(--bg-mid);border:1px solid var(--card-border);color:var(--text-primary);padding:10px 24px;border-radius:10px;font-size:13px;z-index:200;animation:toastIn .3s ease,toastOut .3s ease 1.7s forwards;pointer-events:none;box-shadow:0 8px 32px rgba(0,0,0,0.4)}
@keyframes toastIn{from{opacity:0;transform:translateX(-50%) translateY(-10px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
@keyframes toastOut{from{opacity:1}to{opacity:0}}

/* Selection color */
::selection{background:var(--accent);color:#1a1a24}

/* Pull to refresh */
.pull-indicator{position:fixed;top:0;left:50%;transform:translateX(-50%) translateY(-60px);z-index:50;display:flex;flex-direction:column;align-items:center;gap:4px;transition:transform .3s cubic-bezier(.25,.46,.45,.94);pointer-events:none}
.pull-indicator.visible{transform:translateX(-50%) translateY(12px)}
.pull-indicator.refreshing{transform:translateX(-50%) translateY(12px)}
.pull-spinner{width:28px;height:28px;border:3px solid var(--card-border);border-top-color:var(--macaron-pink);border-radius:50%;transition:border-top-color .2s}
.pull-indicator.refreshing .pull-spinner{animation:spin .6s linear infinite}
.pull-text{font-size:11px;color:var(--text-secondary);letter-spacing:.5px}
@keyframes spin{from{transform:rotate(0)}to{transform:rotate(360deg)}}
</style>
</head>
<body>

<!-- Pull to refresh indicator -->
<div class="pull-indicator" id="pullIndicator">
  <div class="pull-spinner"></div>
  <div class="pull-text" id="pullText">下拉刷新</div>
</div>

<header class="header">
  <div class="header-top">
    <button class="header-settings" onclick="openSettings()" title="同步设置">⚙</button>
  </div>
  <div class="header-nav">
    <button class="header-arrow" id="prevDay" onclick="changeDay(-1)">◀</button>
    <div class="header-center">
      <div class="header-date" id="headerDate"></div>
      <div class="header-weekday" id="headerWeekday"></div>
      <div class="header-today-badge" id="todayBadge" style="display:none">今天</div>
      <div id="syncIndicator"></div>
    </div>
    <button class="header-arrow" id="nextDay" onclick="changeDay(1)">▶</button>
  </div>
  <div class="header-line"></div>
</header>

<main class="main">
  <div class="cards-grid" id="cardsGrid"></div>
</main>

<div class="bottom-bar" id="bottomBar">
  <button class="btn btn-merge" onclick="mergeCards()" title="合并全部卡片">合并</button>
  <button class="btn btn-add" id="addBtn" onclick="addNewCard()" title="新增卡片">记一下</button>
  <button class="btn btn-clear" onclick="confirmClear()" title="清空全部">清空</button>
</div>

<script>
const STORAGE_KEY = 'diary_cards_';
const CURRENT_DATE_KEY = 'diary_current_date';
const CLOUD_CONFIG_KEY = 'diary_cloud_config';
let cards = [];
let editingId = null;
let isNewCardOpen = false;
let currentDate = null;

// ===== Supabase Configuration (pure REST API, no SDK needed) =====
let cloudConfig = { supabaseUrl: '', supabaseKey: '', syncCode: '', connected: false };

function cloudHeaders() {
  return {
    'Content-Type': 'application/json',
    'apikey': cloudConfig.supabaseKey,
    'Authorization': 'Bearer ' + cloudConfig.supabaseKey,
    'Prefer': 'return=representation'
  };
}

function cloudUrl(table) {
  const base = cloudConfig.supabaseUrl.replace(/\/$/, '');
  return base + '/rest/v1/' + table;
}

function loadCloudConfig() {
  try {
    const raw = localStorage.getItem(CLOUD_CONFIG_KEY);
    if (raw) { const saved = JSON.parse(raw); cloudConfig = { ...cloudConfig, ...saved }; }
  } catch(e) {}
}

function saveCloudConfig() {
  localStorage.setItem(CLOUD_CONFIG_KEY, JSON.stringify({
    supabaseUrl: cloudConfig.supabaseUrl,
    supabaseKey: cloudConfig.supabaseKey,
    syncCode: cloudConfig.syncCode,
    connected: cloudConfig.connected
  }));
}

async function initCloud() {
  if (!cloudConfig.supabaseUrl || !cloudConfig.supabaseKey || !cloudConfig.syncCode) {
    cloudConfig.connected = false;
    updateSyncIndicator();
    return false;
  }
  try {
    // Test connection with a simple query
    const url = cloudUrl('diary') + '?sync_code=eq.' + encodeURIComponent(cloudConfig.syncCode) + '&date=eq.' + getTodayKey() + '&limit=1';
    const res = await fetch(url, { method: 'GET', headers: cloudHeaders() });
    if (!res.ok) {
      const errBody = await res.text().catch(() => '');
      throw new Error(res.status + ': ' + (errBody || res.statusText));
    }
    await res.json(); // consume body
    cloudConfig.connected = true;
    cloudConfig.lastError = '';
    saveCloudConfig();
    updateSyncIndicator();
    return true;
  } catch(e) {
    console.error('Cloud init failed:', e);
    cloudConfig.connected = false;
    cloudConfig.lastError = e.message || String(e);
    saveCloudConfig();
    updateSyncIndicator();
    return false;
  }
}

async function disconnectCloud() {
  cloudConfig.connected = false;
  saveCloudConfig();
  updateSyncIndicator();
}

// ===== Cloud Data Operations =====
async function cloudLoadCards(dateKey) {
  if (!cloudConfig.connected) return null;
  try {
    const url = cloudUrl('diary') + '?sync_code=eq.' + encodeURIComponent(cloudConfig.syncCode) + '&date=eq.' + encodeURIComponent(dateKey) + '&limit=1';
    const res = await fetch(url, { method: 'GET', headers: cloudHeaders() });
    if (!res.ok) throw new Error(res.status);
    const data = await res.json();
    if (data && data.length > 0) {
      return { cards: data[0].cards || [], updatedAt: new Date(data[0].updated_at).getTime() || 0, id: data[0].id };
    }
    return { cards: null, updatedAt: 0, id: null };
  } catch(e) {
    console.error('Cloud load failed:', e);
    return null;
  }
}

async function cloudSaveCards(dateKey, cardsData) {
  if (!cloudConfig.connected) return false;
  try {
    // Check if record exists
    const checkUrl = cloudUrl('diary') + '?sync_code=eq.' + encodeURIComponent(cloudConfig.syncCode) + '&date=eq.' + encodeURIComponent(dateKey) + '&select=id&limit=1';
    const checkRes = await fetch(checkUrl, { method: 'GET', headers: cloudHeaders() });
    if (!checkRes.ok) throw new Error(checkRes.status);
    const existing = await checkRes.json();

    const payload = { cards: cardsData, updated_at: new Date().toISOString() };

    if (existing && existing.length > 0) {
      // Update via PATCH with id filter
      const updateUrl = cloudUrl('diary') + '?id=eq.' + existing[0].id;
      const res = await fetch(updateUrl, { method: 'PATCH', headers: cloudHeaders(), body: JSON.stringify(payload) });
      if (!res.ok) throw new Error(res.status);
    } else {
      // Insert
      payload.sync_code = cloudConfig.syncCode;
      payload.date = dateKey;
      const insertHeaders = { ...cloudHeaders() };
      delete insertHeaders['Prefer'];
      const res = await fetch(cloudUrl('diary'), { method: 'POST', headers: insertHeaders, body: JSON.stringify([payload]) });
      if (!res.ok) throw new Error(res.status);
    }
    return true;
  } catch(e) {
    console.error('Cloud save failed:', e);
    return false;
  }
}

async function cloudDeleteCards(dateKey) {
  if (!cloudConfig.connected) return false;
  try {
    const url = cloudUrl('diary') + '?sync_code=eq.' + encodeURIComponent(cloudConfig.syncCode) + '&date=eq.' + encodeURIComponent(dateKey);
    const res = await fetch(url, { method: 'DELETE', headers: cloudHeaders() });
    if (!res.ok) throw new Error(res.status);
    return true;
  } catch(e) {
    console.error('Cloud delete failed:', e);
    return false;
  }
}

// Sync indicator
function updateSyncIndicator() {
  const el = document.getElementById('syncIndicator');
  if (!el) return;
  const refreshBtn = '<span class="refresh-btn" onclick="location.reload()" title="刷新页面">⟳</span>';
  if (cloudConfig.connected) {
    el.innerHTML = '<div class="sync-indicator sync-on"><span class="sync-dot"></span>已同步</div>' + refreshBtn;
  } else {
    el.innerHTML = '<div class="sync-indicator sync-off"><span class="sync-dot"></span>本地存储</div>' + refreshBtn;
  }
}

// ===== Settings Modal =====
function openSettings() {
  const isConnected = cloudConfig.connected;
  const statusClass = isConnected ? 'settings-status-on' : (cloudConfig.lastError ? 'settings-status-err' : 'settings-status-off');
  let statusText = isConnected ? '☁️ 已连接 · 同步码: ' + cloudConfig.syncCode : '📁 仅本地存储';
  if (!isConnected && cloudConfig.lastError) statusText = '❌ ' + cloudConfig.lastError;

  showModal(`
    <div class="modal-title">数据同步设置</div>
    <div class="modal-body">
      <div class="settings-section">
        <div class="settings-label">Supabase 项目 URL</div>
        <input class="settings-input" id="settingsUrl" placeholder="https://xxxxx.supabase.co" value="${escapeHtml(cloudConfig.supabaseUrl)}">
        <div class="settings-hint">前往 <a href="https://supabase.com" target="_blank" style="color:var(--accent)">supabase.com</a> 创建免费项目，在 Settings → API 中复制 Project URL</div>
      </div>
      <div class="settings-section">
        <div class="settings-label">Supabase 匿名密钥 (anon key)</div>
        <input class="settings-input" id="settingsKey" placeholder="eyJhbGciOi..." value="${escapeHtml(cloudConfig.supabaseKey)}">
        <div class="settings-hint">在 Settings → API 中复制 anon public 密钥（以 sb_publishable_ 或 eyJ 开头均可）</div>
      </div>
      <div class="settings-section">
        <div class="settings-label">同步码</div>
        <input class="settings-input" id="settingsSyncCode" placeholder="设置一个同步码，其他设备输入相同码即可同步" value="${escapeHtml(cloudConfig.syncCode)}">
        <div class="settings-hint">同步码是你的跨设备身份标识，类似密码。<br>在另一台设备输入相同同步码，即可访问同一份数据。</div>
      </div>
      <div class="settings-status ${statusClass}" id="settingsStatus">${statusText}</div>
    </div>
    <div class="modal-actions" style="justify-content:space-between">
      ${isConnected ? '<button class="btn btn-danger" onclick="handleDisconnect()">断开连接</button>' : '<div></div>'}
      <div style="display:flex;gap:8px">
        <button class="btn btn-ghost" onclick="closeModal()">关闭</button>
        <button class="btn btn-success" onclick="handleConnect()">连接</button>
      </div>
    </div>
  `);
}

async function handleConnect() {
  const url = document.getElementById('settingsUrl').value.trim();
  const key = document.getElementById('settingsKey').value.trim();
  const syncCode = document.getElementById('settingsSyncCode').value.trim();

  if (!url || !key || !syncCode) {
    showToast('请填写 URL、密钥和同步码');
    return;
  }

  const statusEl = document.getElementById('settingsStatus');
  statusEl.className = 'settings-status settings-status-off';
  statusEl.textContent = '⏳ 正在连接...';

  cloudConfig.supabaseUrl = url;
  cloudConfig.supabaseKey = key;
  cloudConfig.syncCode = syncCode;

  const success = await initCloud();
  if (success) {
    statusEl.className = 'settings-status settings-status-on';
    statusEl.textContent = '☁️ 已连接 · 同步码: ' + syncCode;
    showToast('云端连接成功');
    await syncFromCloud();
    render();
    closeModal();
    openSettings();
  } else {
    statusEl.className = 'settings-status settings-status-err';
    const errMsg = cloudConfig.lastError || '请检查 URL、密钥和网络';
    statusEl.textContent = '❌ 连接失败: ' + errMsg;
    showToast('连接失败');
  }
}

async function handleDisconnect() {
  await disconnectCloud();
  closeModal();
  showToast('已断开云端连接');
  render();
}

// ===== Sync Logic =====
async function syncFromCloud() {
  if (!cloudConfig.connected) return;
  const cloudData = await cloudLoadCards(currentDate);
  if (cloudData && cloudData.cards !== null) {
    const localUpdatedAt = parseInt(localStorage.getItem(STORAGE_KEY + currentDate + '_ts') || '0');
    if (cloudData.updatedAt > localUpdatedAt) {
      cards = cloudData.cards;
      localStorage.setItem(STORAGE_KEY + currentDate, JSON.stringify(cards));
      localStorage.setItem(STORAGE_KEY + currentDate + '_ts', String(cloudData.updatedAt));
    }
  }
}

async function syncAllFromCloud() {
  if (!cloudConfig.connected) return;
  try {
    const url = cloudUrl('diary') + '?sync_code=eq.' + encodeURIComponent(cloudConfig.syncCode) + '&select=date,cards,updated_at&limit=100';
    const res = await fetch(url, { method: 'GET', headers: cloudHeaders() });
    if (!res.ok) throw new Error(res.status);
    const data = await res.json();
    if (data) {
      data.forEach(doc => {
        const localTs = parseInt(localStorage.getItem(STORAGE_KEY + doc.date + '_ts') || '0');
        const cloudTs = new Date(doc.updated_at).getTime() || 0;
        if (cloudTs > localTs) {
          localStorage.setItem(STORAGE_KEY + doc.date, JSON.stringify(doc.cards || []));
          localStorage.setItem(STORAGE_KEY + doc.date + '_ts', String(cloudTs));
        }
      });
      loadCardsLocal();
    }
  } catch(e) {
    console.error('Sync all from cloud failed:', e);
  }
}

// ===== Date helpers =====
function getTodayKey() { return dateToKey(new Date()); }
function dateToKey(d) { return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`; }
function keyToDate(key) { const [y,m,d] = key.split('-').map(Number); return new Date(y, m-1, d); }
function formatDateHeader(dateStr) { const d = keyToDate(dateStr); return `${d.getFullYear()}年${d.getMonth()+1}月${d.getDate()}日`; }
function getWeekday(dateStr) { const days = ['星期日','星期一','星期二','星期三','星期四','星期五','星期六']; return days[keyToDate(dateStr).getDay()]; }
function isToday(dateStr) { return dateStr === getTodayKey(); }

// ===== Day navigation =====
function changeDay(delta) {
  const d = keyToDate(currentDate);
  d.setDate(d.getDate() + delta);
  const newKey = dateToKey(d);
  if (newKey > getTodayKey()) return;
  currentDate = newKey;
  localStorage.setItem(CURRENT_DATE_KEY, currentDate);
  editingId = null;
  isNewCardOpen = false;
  loadCards();
  updateHeader();
  render();
}

function updateHeader() {
  document.getElementById('headerDate').textContent = formatDateHeader(currentDate);
  document.getElementById('headerWeekday').textContent = getWeekday(currentDate);
  const badge = document.getElementById('todayBadge');
  const nextBtn = document.getElementById('nextDay');
  if (isToday(currentDate)) { badge.style.display = 'inline-block'; nextBtn.disabled = true; }
  else { badge.style.display = 'none'; nextBtn.disabled = false; }
  document.getElementById('addBtn').style.display = isToday(currentDate) ? 'flex' : 'none';
  updateSyncIndicator();
}

// ===== Storage (local cache + cloud sync) =====
function loadCardsLocal() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY + currentDate);
    cards = raw ? JSON.parse(raw) : [];
  } catch(e) { cards = []; }
}

async function loadCards() {
  loadCardsLocal();
  if (cloudConfig.connected) {
    const cloudData = await cloudLoadCards(currentDate);
    if (cloudData && cloudData.cards !== null) {
      const localTs = parseInt(localStorage.getItem(STORAGE_KEY + currentDate + '_ts') || '0');
      if (cloudData.updatedAt > localTs) {
        cards = cloudData.cards;
        localStorage.setItem(STORAGE_KEY + currentDate, JSON.stringify(cards));
        localStorage.setItem(STORAGE_KEY + currentDate + '_ts', String(cloudData.updatedAt));
      }
    }
  }
}

function saveCards() {
  localStorage.setItem(STORAGE_KEY + currentDate, JSON.stringify(cards));
  const ts = String(Date.now());
  localStorage.setItem(STORAGE_KEY + currentDate + '_ts', ts);
  if (cloudConfig.connected) {
    cloudSaveCards(currentDate, cards).catch(e => console.error('Background cloud save failed:', e));
  }
}

// ===== Render =====
function render() {
  const grid = document.getElementById('cardsGrid');
  const canAdd = isToday(currentDate);

  if (cards.length === 0 && !isNewCardOpen) {
    grid.innerHTML = `
      <div class="empty-state" style="grid-column:1/-1">
        <div class="empty-state-icon">✦</div>
        <div class="empty-state-text">${canAdd ? '今天还没有记录<br>点击下方「记一下」开始书写' : '这一天没有记录'}</div>
      </div>`;
    return;
  }

  let html = '';
  cards.forEach((card, i) => {
    if (editingId === card.id) {
      html += `
        <div class="card-wrapper" style="animation-delay:${i*0.04}s">
          <div class="card editing" data-id="${card.id}">
            <textarea class="card-edit-area" id="editText_${card.id}">${escapeHtml(card.text)}</textarea>
            <div class="card-edit-actions">
              <button class="btn btn-ghost" onclick="cancelEdit()">取消</button>
              <button class="btn btn-primary" onclick="saveEdit('${card.id}')">保存</button>
            </div>
          </div>
        </div>`;
    } else {
      html += `
        <div class="card-wrapper" style="animation-delay:${i*0.04}s">
          <div class="card" data-id="${card.id}" ondblclick="startEdit('${card.id}')">
            <div class="card-text">${escapeHtml(card.text)}</div>
          </div>
        </div>`;
    }
  });

  if (isNewCardOpen && canAdd) {
    html += `
      <div class="new-card" id="newCardForm">
        <textarea class="new-card-textarea" id="newCardText" placeholder="写下此刻的想法…" autofocus></textarea>
        <div class="new-card-actions">
          <button class="btn btn-ghost" onclick="cancelNewCard()">取消</button>
          <button class="btn btn-primary" onclick="saveNewCard()">保存</button>
        </div>
      </div>`;
  }

  grid.innerHTML = html;
  document.querySelectorAll('.card-wrapper .card:not(.editing)').forEach(bindSwipe);

  const bottomBar = document.getElementById('bottomBar');
  if (isNewCardOpen || editingId) {
    bottomBar.style.opacity = '0'; bottomBar.style.pointerEvents = 'none';
    bottomBar.style.transform = 'translateX(-50%) translateY(20px)';
  } else {
    bottomBar.style.opacity = '1'; bottomBar.style.pointerEvents = 'auto';
    bottomBar.style.transform = 'translateX(-50%) translateY(0)';
  }

  function scrollToTarget(el) {
    if (!el) return;
    el.scrollIntoView({behavior:'smooth',block:'center'});
    setTimeout(() => el.scrollIntoView({behavior:'smooth',block:'center'}), 300);
    setTimeout(() => el.scrollIntoView({behavior:'smooth',block:'center'}), 600);
  }
  if (editingId) {
    const ta = document.getElementById('editText_' + editingId);
    if (ta) { ta.focus({preventScroll:true}); ta.selectionStart = ta.value.length; scrollToTarget(ta.closest('.card-wrapper') || ta); }
  }
  if (isNewCardOpen) {
    const form = document.getElementById('newCardForm'); const ta = document.getElementById('newCardText');
    scrollToTarget(form || ta); if (ta) { ta.focus({preventScroll:true}); ta.focus(); }
  }
}

function escapeHtml(str) { const div = document.createElement('div'); div.textContent = str; return div.innerHTML; }

// ===== Swipe to delete =====
function bindSwipe(cardEl) {
  let startX=0,startY=0,currentX=0,swiping=false,directionLocked=false,isHorizontal=false;
  function onStart(e) {
    if (cardEl.classList.contains('editing')) return;
    const touch = e.touches ? e.touches[0] : e;
    startX=touch.clientX; startY=touch.clientY; currentX=0; swiping=true; directionLocked=false; isHorizontal=false;
    cardEl.classList.add('swiping');
  }
  function onMove(e) {
    if (!swiping) return;
    const touch = e.touches ? e.touches[0] : e;
    const dx=touch.clientX-startX, dy=touch.clientY-startY;
    if (!directionLocked && (Math.abs(dx)>8||Math.abs(dy)>8)) { directionLocked=true; isHorizontal=Math.abs(dx)>Math.abs(dy); }
    if (!isHorizontal) return;
    e.preventDefault();
    currentX=Math.min(0,dx);
    const progress=Math.abs(currentX)/100;
    cardEl.style.transform=`translateX(${currentX}px)`;
    cardEl.style.opacity=Math.max(0.4,1-progress*0.6);
    if (progress>0.3) cardEl.classList.add('swiping-deleting'); else cardEl.classList.remove('swiping-deleting');
  }
  function onEnd() {
    if (!swiping) return;
    swiping=false; cardEl.classList.remove('swiping','swiping-deleting'); cardEl.style.transform=''; cardEl.style.opacity='';
    if (isHorizontal && currentX<-50) {
      const wrapper=cardEl.closest('.card-wrapper');
      if (wrapper) { wrapper.style.transition='opacity .2s ease'; wrapper.style.opacity='0'; }
      setTimeout(()=>deleteCard(cardEl.dataset.id),200);
    }
  }
  cardEl.addEventListener('touchstart',onStart,{passive:true});
  cardEl.addEventListener('touchmove',onMove,{passive:false});
  cardEl.addEventListener('touchend',onEnd);
  cardEl.addEventListener('mousedown',onStart);
  document.addEventListener('mousemove',onMove);
  document.addEventListener('mouseup',onEnd);
  cardEl._cleanup=()=>{document.removeEventListener('mousemove',onMove);document.removeEventListener('mouseup',onEnd);};
}

// ===== Card CRUD =====
function addNewCard() {
  if (isNewCardOpen) return;
  if (!isToday(currentDate)) { showToast('只能为今天添加记录'); return; }
  isNewCardOpen=true; editingId=null; render();
}
function cancelNewCard() { isNewCardOpen=false; render(); }

function saveNewCard() {
  const ta=document.getElementById('newCardText'); const text=ta?ta.value.trim():'';
  if (!text) { showToast('内容不能为空'); return; }
  const saveTime=new Date();
  const timestamp=`${String(saveTime.getHours()).padStart(2,'0')}:${String(saveTime.getMinutes()).padStart(2,'0')}:${String(saveTime.getSeconds()).padStart(2,'0')}`;
  cards.push({ id:'c_'+Date.now()+'_'+Math.random().toString(36).substr(2,5), text:timestamp+' > '+text, created:Date.now() });
  isNewCardOpen=false; saveCards(); render(); showToast('已保存');
}

function startEdit(id) {
  if (!isToday(currentDate)) { showToast('只能编辑今天的记录'); return; }
  editingId=id; isNewCardOpen=false; render();
}
function cancelEdit() { editingId=null; render(); }

function saveEdit(id) {
  const ta=document.getElementById('editText_'+id); const text=ta?ta.value.trim():'';
  if (!text) { showToast('内容不能为空'); return; }
  const card=cards.find(c=>c.id===id); if (card) card.text=text;
  editingId=null; saveCards(); render(); showToast('已更新');
}

function deleteCard(id) {
  cards=cards.filter(c=>c.id!==id); saveCards(); render(); showToast('已删除');
}

// ===== Merge cards =====
function mergeCards() {
  if (cards.length===0) { showToast('没有卡片可合并'); return; }
  const title=formatDateHeader(currentDate)+' '+getWeekday(currentDate);
  const merged=title+'\n\n'+cards.map(c=>c.text).join('\n');
  showModal(`
    <div class="modal-title">合并内容</div>
    <div class="modal-body"><div class="modal-merged-text" id="mergedText">${escapeHtml(merged)}</div></div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModal()">关闭</button>
      <button class="btn btn-primary" onclick="copyMerged()">复制</button>
    </div>`);
}
function copyMerged() {
  const el=document.getElementById('mergedText'); if (!el) return;
  const text=el.textContent;
  navigator.clipboard.writeText(text).then(()=>showToast('已复制到剪贴板')).catch(()=>{
    const ta=document.createElement('textarea'); ta.value=text; document.body.appendChild(ta); ta.select();
    document.execCommand('copy'); document.body.removeChild(ta); showToast('已复制到剪贴板');
  });
}

// ===== Clear all =====
function confirmClear() {
  if (cards.length===0 && !isNewCardOpen) { showToast('没有内容可清空'); return; }
  showModal(`
    <div class="confirm-icon">⚠️</div>
    <div class="modal-title" style="text-align:center">确认清空全部内容？</div>
    <div class="confirm-text">此操作将删除${isToday(currentDate)?'今天的':'这一天的'}所有记录，且无法恢复。</div>
    <div class="modal-actions" style="justify-content:center">
      <button class="btn btn-ghost" onclick="closeModal()">取消</button>
      <button class="btn btn-danger" onclick="clearAll()">确认清空</button>
    </div>`);
}
function clearAll() {
  cards=[]; isNewCardOpen=false; editingId=null; saveCards();
  if (cloudConfig.connected) cloudDeleteCards(currentDate);
  closeModal(); render(); showToast('已清空');
}

// ===== Modal =====
function showModal(html) {
  const overlay=document.createElement('div'); overlay.className='modal-overlay'; overlay.id='modalOverlay';
  overlay.innerHTML=`<div class="modal">${html}</div>`;
  overlay.addEventListener('click',function(e){if(e.target===overlay)closeModal();});
  document.body.appendChild(overlay);
}
function closeModal() { const m=document.getElementById('modalOverlay'); if (m) m.remove(); }

// ===== Toast =====
function showToast(msg) {
  const t=document.createElement('div'); t.className='toast'; t.textContent=msg;
  document.body.appendChild(t); setTimeout(()=>t.remove(),2200);
}

// ===== Keyboard shortcuts =====
document.addEventListener('keydown', function(e) {
  if (e.key==='Escape') {
    if (document.getElementById('modalOverlay')) { closeModal(); return; }
    if (editingId) { cancelEdit(); return; }
    if (isNewCardOpen) { cancelNewCard(); return; }
  }
  if (e.key==='Enter' && !e.shiftKey) {
    const active=document.activeElement;
    if (active && (active.id==='newCardText' || active.id.startsWith('editText_'))) {
      e.preventDefault();
      if (isNewCardOpen) { saveNewCard(); return; }
      if (editingId) { saveEdit(editingId); return; }
    }
  }
});

// ===== Mobile keyboard handling =====
if (window.visualViewport) {
  let prevH=window.visualViewport.height;
  window.visualViewport.addEventListener('resize',()=>{
    const curH=window.visualViewport.height;
    if (prevH-curH>100) {
      const active=document.activeElement;
      if (active && (active.id==='newCardText' || active.id.startsWith('editText_'))) {
        const target=active.closest('.card-wrapper,.new-card')||active;
        setTimeout(()=>target.scrollIntoView({behavior:'smooth',block:'center'}),50);
      }
    }
    prevH=curH;
  });
}

// ===== Init =====
async function init() {
  try {
    loadCloudConfig();
    const saved=localStorage.getItem(CURRENT_DATE_KEY);
    const today=getTodayKey();
    currentDate=(saved && saved<=today)?saved:today;
    updateHeader();

    if (cloudConfig.supabaseUrl && cloudConfig.supabaseKey && cloudConfig.syncCode) {
      try {
        const connected = await initCloud();
        if (connected) {
          await syncAllFromCloud();
        }
      } catch(cloudErr) {
        console.error('Cloud init error (non-fatal):', cloudErr);
      }
    }

    loadCardsLocal();
    if (cloudConfig.connected) {
      try { await syncFromCloud(); } catch(e) { console.error('Sync error (non-fatal):', e); }
    }
  } catch(e) {
    console.error('Init error:', e);
  }
  // Always render, even if cloud fails
  render();
}

init();

// ===== Pull to Refresh =====
(function(){
  const THRESHOLD = 80; // px to trigger refresh
  const indicator = document.getElementById('pullIndicator');
  const pullText = document.getElementById('pullText');
  let startY = 0, pulling = false, canPull = true;

  function isAtTop() { return window.scrollY <= 0; }

  function onstart(e) {
    if (!isAtTop()) { canPull = false; return; }
    canPull = true;
    const pt = e.touches ? e.touches[0] : e;
    startY = pt.clientY;
    pulling = false;
  }

  function onmove(e) {
    if (!canPull) return;
    const pt = e.touches ? e.touches[0] : e;
    const dy = pt.clientY - startY;
    if (dy <= 0) { pulling = false; indicator.classList.remove('visible'); return; }
    // Only intercept if vertical pull is dominant
    if (!pulling && dy > 10) { pulling = true; }
    if (!pulling) return;
    e.preventDefault();
    const dist = Math.min(dy * 0.5, THRESHOLD + 20); // rubber band
    const progress = Math.min(dist / THRESHOLD, 1);
    indicator.style.transform = `translateX(-50%) translateY(${-60 + dist + 12}px)`;
    indicator.classList.toggle('visible', dist > 10);
    indicator.classList.remove('refreshing');
    if (progress >= 1) {
      pullText.textContent = '松手刷新';
      indicator.querySelector('.pull-spinner').style.borderTopColor = 'var(--macaron-green)';
    } else {
      pullText.textContent = '下拉刷新';
      indicator.querySelector('.pull-spinner').style.borderTopColor = 'var(--macaron-pink)';
    }
  }

  async function onend() {
    if (!pulling) return;
    canPull = false;
    // Check if pulled past threshold
    const currentTranslate = parseFloat(indicator.style.transform.match(/translateY\((.+?)px\)/)?.[1] || 0);
    if (currentTranslate >= -10) {
      // Trigger refresh
      indicator.style.transform = '';
      indicator.classList.add('visible', 'refreshing');
      pullText.textContent = '刷新中…';
      indicator.querySelector('.pull-spinner').style.borderTopColor = 'var(--macaron-green)';

      // Do the refresh
      try {
        if (cloudConfig.connected) {
          await syncAllFromCloud();
          await syncFromCloud();
        }
      } catch(e) { console.error('Pull refresh sync error:', e); }
      loadCardsLocal();
      render();
      showToast('已刷新');

      // Hold spinner for a moment
      await new Promise(r => setTimeout(r, 500));
    }
    // Reset
    indicator.classList.remove('visible', 'refreshing');
    indicator.style.transform = '';
    pullText.textContent = '下拉刷新';
    indicator.querySelector('.pull-spinner').style.borderTopColor = 'var(--macaron-pink)';
    pulling = false;
  }

  // Touch events (mobile)
  document.addEventListener('touchstart', onstart, { passive: true });
  document.addEventListener('touchmove', onmove, { passive: false });
  document.addEventListener('touchend', onend);
  // Mouse events (desktop)
  document.addEventListener('mousedown', onstart);
  document.addEventListener('mousemove', onmove);
  document.addEventListener('mouseup', onend);
})();
</script>
</body>
</html>
